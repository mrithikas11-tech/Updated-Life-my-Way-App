<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.canigetafiver.lifemyway.web.expense.AddExpenseController"
      stylesheets="@styles.css">
    <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

    <Label text="Add Expense" styleClass="title"/>

    <HBox spacing="16" alignment="CENTER_LEFT" maxWidth="700">
        <Label text="Category" styleClass="form-label" prefWidth="140"/>
        <ChoiceBox fx:id="categoryChoiceBox" prefWidth="200" onContextMenuRequested="#selectCategory"/>
    </HBox>

    <HBox spacing="16" alignment="CENTER_LEFT" maxWidth="700">
        <Label text="Date" styleClass="form-label" prefWidth="140"/>
        <DatePicker fx:id="datePicker" editable="true"/>
    </HBox>

    <HBox spacing="16" alignment="CENTER_LEFT" maxWidth="700">
        <Label text="Payment Method" styleClass="form-label" prefWidth="140"/>
        <ChoiceBox fx:id="paymentMethodChoiceBox" prefWidth="200"/>
    </HBox>

    <HBox spacing="16" alignment="CENTER_LEFT" maxWidth="700">
        <Label text="Amount" styleClass="form-label" prefWidth="140"/>
        <TextField fx:id="amountTextField" promptText="0.00" prefWidth="200" onAction="#updateAmount"/>
    </HBox>

    <HBox spacing="16" alignment="CENTER_LEFT" maxWidth="700">
        <Label text="Vendor" styleClass="form-label" prefWidth="140"/>
        <TextField fx:id="vendorTextField" promptText="Vendor" prefWidth="200"/>
    </HBox>

    <HBox spacing="16" alignment="CENTER_LEFT" maxWidth="700">
        <Label text="Description" styleClass="form-label" prefWidth="140"/>
        <TextArea fx:id="descriptionTextArea" promptText="Expense Description" prefWidth="500" prefHeight="100"/>
    </HBox>

    <HBox spacing="16" alignment="CENTER">
        <Button fx:id="cancelButton" text="Cancel" styleClass="secondary-button" onAction="#cancel"/>
        <Button fx:id="save" text="Save" styleClass="primary-button" onAction="#saveExpense"/>
    </HBox>
</VBox>
