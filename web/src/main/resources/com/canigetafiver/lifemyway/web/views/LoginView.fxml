<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="root, login-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.canigetafiver.lifemyway.web.controller.LoginController">
    <VBox alignment="CENTER" maxWidth="420" spacing="14" styleClass="card">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32"/>
        </padding>
        <Label text="Life My Way" styleClass="title"/>
        <Label text="Sign in to track your spending" styleClass="subtitle"/>
        <Region prefHeight="8"/>
        <Label text="Username" styleClass="form-label"/>
        <TextField fx:id="usernameField" promptText="e.g. demo" styleClass="text-field"/>
        <Label text="Password" styleClass="form-label"/>
        <PasswordField fx:id="passwordField" promptText="Your password" styleClass="text-field"/>
        <Label fx:id="statusLabel" text="" wrapText="true"/>
        <Button text="Log In"
                onAction="#onLogin"
                defaultButton="true"
                maxWidth="Infinity"
                styleClass="primary-button"/>
        <HBox alignment="CENTER" spacing="6">
            <Label text="No account?" styleClass="muted-label"/>
            <Hyperlink text="Create one" onAction="#onGoToRegister" styleClass="link"/>
        </HBox>
        <Label text="Demo account: demo / demo123" styleClass="hint-label"/>
    </VBox>
</StackPane>
