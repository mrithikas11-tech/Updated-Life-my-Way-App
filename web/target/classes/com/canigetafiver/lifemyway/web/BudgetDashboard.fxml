<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           fx:controller="com.canigetafiver.lifemyway.web.BudgetDashboardController">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
        <content>
            <VBox spacing="16" prefWidth="1280">
                <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>

                <HBox spacing="12">
                    <Button text="Back" onAction="#handleBackButton"/>
                    <Label fx:id="currentBudgetLabel" text="Your Budget"/>
                </HBox>

                <VBox spacing="10">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <HBox spacing="16">
                        <Label text="Total Budget"/>
                        <Label fx:id="totalBudgetAmount" text="$0.00"/>
                    </HBox>
                    <ProgressBar fx:id="totalProgressBar" prefWidth="600" progress="0.0"/>
                    <Label fx:id="totalProgressLabel" text="$0.00 allocated of $0.00"/>
                </VBox>

                <VBox spacing="10">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label text="Category Breakdown"/>
                    <VBox fx:id="budgetsContainer" spacing="8"/>
                </VBox>

                <VBox spacing="8">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label text="Notifications"/>
                    <Label fx:id="noAlertsLabel" text="No alerts — you are on track!"/>
                    <VBox fx:id="notificationsContainer" spacing="6"/>
                </VBox>

                <VBox spacing="8">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label text="Expenses"/>
                    <VBox fx:id="expensesContainer" spacing="6"/>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

</StackPane>
