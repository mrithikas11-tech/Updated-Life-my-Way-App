<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.canigetafiver.lifemyway.web.BudgetSystemController"
           alignment="TOP_CENTER"
           stylesheets="@styles.css">

    <VBox spacing="10"
          maxWidth="1280" maxHeight="720"
          alignment="CENTER"
          styleClass="card">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="Pick your Budget:" styleClass="title"/>

        <HBox alignment="CENTER" spacing="10">
            <Button text="Weekly" styleClass="primary-button" onAction="#handleWeekly"/>
            <Button text="Monthly" styleClass="secondary-button" onAction="#handleMonthly"/>
        </HBox>

        <TextField fx:id="weeklyAmountField"
                   promptText="Enter Weekly amount:"
                   visible="false"
                   managed="false"
                   onAction="#handleWeeklyAmount"/>

        <TextField fx:id="monthlyAmountField"
                   promptText="Enter Monthly amount:"
                   visible="false"
                   managed="false"
                   onAction="#handleMonthlyAmount"/>

        <Label text="Press enter after you pick your choice"/>

        <Button text="← Back to Home" styleClass="secondary-button" onAction="#handleBackButton"/>

    </VBox>

</StackPane>
