<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="CENTER" prefHeight="499.0" prefWidth="517.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.canigetafiver.lifemyway.web.expense.EditExpenseController">
   <children>
      <Label alignment="CENTER" contentDisplay="CENTER" text="Edit Expense">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <HBox alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="565.0" spacing="55.0">
         <children>
            <Label text="Category">
               <padding>
                  <Insets left="5.0" />
               </padding>
            </Label>
            <ChoiceBox fx:id="categoryChoiceBox" prefWidth="150.0" />
         </children>
      </HBox>
      <HBox alignment="BASELINE_LEFT" prefHeight="47.0" prefWidth="565.0" spacing="78.0">
         <children>
            <Label text="Date" />
            <DatePicker fx:id="datePicker" />
         </children>
         <padding>
            <Insets left="5.0" />
         </padding>
      </HBox>
      <HBox alignment="BASELINE_LEFT" prefHeight="50.0" prefWidth="565.0" spacing="10.0">
         <children>
            <Label text="Payment Method" />
            <ChoiceBox fx:id="paymentMethodChoiceBox" prefWidth="150.0" />
         </children>
         <padding>
            <Insets left="5.0" />
         </padding>
      </HBox>
      <HBox alignment="BASELINE_LEFT" prefHeight="36.0" prefWidth="565.0" spacing="60.0">
         <children>
            <Label text="Amount" />
            <TextField fx:id="amountTextField" />
         </children>
         <padding>
            <Insets left="5.0" />
         </padding>
      </HBox>
      <HBox alignment="BASELINE_LEFT" prefHeight="36.0" prefWidth="565.0" spacing="64.0">
         <children>
            <Label text="Vendor" />
            <TextField fx:id="vendorTextField" />
         </children>
         <padding>
            <Insets left="5.0" />
         </padding>
      </HBox>
      <HBox prefHeight="100.0" prefWidth="200.0" spacing="40.0">
         <children>
            <Label text="Description" />
            <TextArea fx:id="descriptionTextArea" prefHeight="100.0" prefWidth="311.0" />
         </children>
         <padding>
            <Insets left="5.0" />
         </padding>
      </HBox>
      <HBox alignment="BASELINE_CENTER" prefHeight="75.0" prefWidth="504.0" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" text="Cancel">
               <HBox.margin>
                  <Insets right="30.0" />
               </HBox.margin>
            </Button>
            <Button mnemonicParsing="false" text="Reset">
               <HBox.margin>
                  <Insets right="20.0" />
               </HBox.margin>
            </Button>
            <Button mnemonicParsing="false" text="Save" />
         </children>
         <opaqueInsets>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </opaqueInsets>
         <padding>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </padding>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </HBox>
      <HBox prefHeight="100.0" prefWidth="200.0" />
   </children>
   <padding>
      <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
   </padding>
</VBox>
